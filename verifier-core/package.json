{
  "name": "provenance-verifier-core",
  "version": "0.1.0",
  "description": "Merged cryptographic provenance + signal integrity verification engine",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "verify-asset": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "api": "node dist/api.js",
    "dev:api": "tsx src/api.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "cli": "tsx src/cli.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
